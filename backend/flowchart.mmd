%% KPI Management System — end-to-end process flows (from frontend mock + Zustand behaviour)
%% Render with Mermaid (https://mermaid.live) or any Mermaid-capable viewer.

flowchart TB
  subgraph KPI["1. KPI definition (KPIItemForm — simplified UI)"]
    KPI_START([Start]) --> KPI_LIB{Import from library?}
    KPI_LIB -->|yes| KPI_FILL[fillFromLibrary: Vision / core presets → form fields]
    KPI_LIB -->|no| KPI_MAN[User enters identity + measurement]
    KPI_FILL --> KPI_VALIDATE
    KPI_MAN --> KPI_VALIDATE{Valid thresholds?}
    KPI_VALIDATE -->|no| KPI_ERR[Return validation errors]
    KPI_VALIDATE -->|yes| KPI_CARRY{allowCarryForward?}
    KPI_CARRY -->|yes| KPI_CFV[Optional carryForwardMissingValue]
    KPI_CARRY -->|no| KPI_SAVE
    KPI_CFV --> KPI_SAVE[Persist kpi_master + thresholds + modes + trade dirs + roles<br/>app applies category / freight defaults]
    KPI_SAVE --> KPI_FORMULA{calculationType = formula?}
    KPI_FORMULA -->|yes| KPI_CALC[kpi_calculation: formula / SP]
    KPI_FORMULA -->|no| KPI_END
    KPI_CALC --> KPI_END([KPI active / draft])
    KPI_ERR --> KPI_START
  end

  subgraph TMPL["2. Template build (TemplateForm)"]
    T_START([Start]) --> T_SCOPE[Business scope + freight scope: modes, trade directions, job_type]
    T_SCOPE --> T_PICK[Select KPIs from kpi_master filtered by scope]
    T_PICK --> T_WEIGHT[Weights must sum 100% when active]
    T_WEIGHT --> T_WEIGHT_OK{Total = 100?}
    T_WEIGHT_OK -->|no| T_ERR[Block activation]
    T_WEIGHT_OK -->|yes| T_SAVE[kpi_template + job_type + lines + roles + shipment modes + trade directions]
    T_SAVE --> T_VER[Increment version + changelog]
    T_VER --> T_END([Template ready])
    T_ERR --> T_PICK
  end

  subgraph ALLOC["3. Target allocation (TemplateAllocation / AllocationForm)"]
    A_START([Start]) --> A_FY[Select fiscal year + template]
    A_FY --> A_NODE[Select org hierarchy node / subject]
    A_NODE --> A_TARGETS[Edit KPITarget rows: annual, H1/H2, Q1–Q4]
    A_TARGETS --> A_SPLIT[autoDistribute: split annual → H/Q]
    A_SPLIT --> A_MISMATCH{H1+H2 = annual<br/>Q1..Q4 = annual?}
    A_MISMATCH -->|no| A_WARN[Show mismatch / fix]
    A_WARN --> A_TARGETS
    A_MISMATCH -->|yes| A_DIST{Distribution view?}
    A_DIST -->|monthly / weekly / daily| A_GRAN[kpi_target_distribution buckets]
    A_DIST -->|annual/quarterly only| A_SAVE
    A_GRAN --> A_SAVE[Upsert kpi_allocation + kpi_target]
    A_SAVE --> A_LOCK{User locks?}
    A_LOCK -->|yes| A_LOCKED[status locked + event]
    A_LOCK -->|no| A_STAT[status draft / confirmed]
    A_LOCKED --> A_END([Targets persisted])
    A_STAT --> A_END
  end

  subgraph ACT["4. Actual capture (ActualsVsTarget / performance rows)"]
    AC_START([Start]) --> AC_ROW[Load or create kpi_actual for period]
    AC_ROW --> AC_SRC{Data source}
    AC_SRC -->|manual| AC_ENTER[User enters actual_value]
    AC_SRC -->|integration| AC_ETL[ETL / API loads actual_value]
    AC_ENTER --> AC_RAG[Compute attainment_pct + RAG vs target]
    AC_ETL --> AC_RAG
    AC_RAG --> AC_APPR{Approval required?}
    AC_APPR -->|yes| AC_WF[Approval workflow]
    AC_APPR -->|no| AC_POST[Posted entry]
    AC_WF --> AC_POST
    AC_POST --> AC_END([Actual stored])
  end

  subgraph CALC["5. KPI calculation & performance"]
    CALC_START([Scheduler / on-demand]) --> CALC_RULE[Resolve kpi_calculation + calculation_type]
    CALC_RULE --> CALC_AGG[Apply aggregation + period_type grain]
    CALC_AGG --> CALC_CF[Apply carry-forward rules if allow_carry_forward]
    CALC_CF --> CALC_SNAP[Upsert kpi_performance snapshot]
    CALC_SNAP --> CALC_END([Dashboards / exports])
  end

  subgraph CMP["6. Target vs actual comparison"]
    CMP_START([Reporting grain]) --> CMP_JOIN[Join kpi_target + kpi_actual + dim_time]
    CMP_JOIN --> CMP_VAR[variance = actual − target]
    CMP_VAR --> CMP_RAG[Classify RAG via thresholds + trend_direction]
    CMP_RAG --> CMP_OUT[Charts / tables / drill-down]
  end

  subgraph CF["7. Carry forward (PeriodTracker)"]
    CF_START([Period close]) --> CF_OPEN{Period open?}
    CF_OPEN -->|no| CF_DONE
    CF_OPEN -->|yes| CF_SUM[Aggregate target vs actual for cycle]
    CF_SUM --> CF_BACKLOG[Compute backlog / shortfall]
    CF_BACKLOG --> CF_LED[kpi_carry_forward_ledger]
    CF_LED --> CF_NEXT[Adjust next_adjusted_target for next cycle]
    CF_NEXT --> CF_CLOSE[kpi_period_instance: closed]
    CF_CLOSE --> CF_DONE([Next period])
  end

  subgraph APPR["8. Approval (allocation & actuals)"]
    AP_START([Submit]) --> AP_PEND[approval_status = pending]
    AP_PEND --> AP_DEC{Reviewer}
    AP_DEC -->|approve| AP_OK[approved]
    AP_DEC -->|reject| AP_REJ[rejected + comment]
    AP_OK --> AP_FIN
    AP_REJ --> AP_FIN([End])
  end

  KPI_END --> TMPL
  T_END --> ALLOC
  ALLOC --> ACT
  ACT --> CALC
  CALC --> CMP
  CMP --> CF
  CF --> ACT

%% Links to reporting
  CALC_END --> CMP_START
